/dts-v1/;
#include "cv181x_base_riscv.dtsi"
#include "cv181x_asic_bga.dtsi"
#include "cv181x_asic_emmc.dtsi"
#include "cv181x_default_memmap.dtsi"

/ {
	model = "FoxioTech Linux-Kit Core";
};

&mipi_rx {
	snsr-reset = <&porta 2 GPIO_ACTIVE_LOW>, <&porta 2 GPIO_ACTIVE_LOW>, <&porta 2 GPIO_ACTIVE_LOW>;
};

&i2c0 {
	status = "disabled";
};

&i2c1 {
	status = "okay";
};

&i2c2 {
	status = "okay";
};

&i2c3 {
	status = "okay";
};

&i2c4 {
	status = "okay";
	
	sw42000_sub: sw42000_sub@28 {
        status = "ok";
        compatible = "lge_sub,sw42000_sub";

        reg = <0x28>;
        interrupt-parent = <&portb>;
        interrupts = <3 0x2002>;
        irqflags = <0x00000002>;

        reset-gpio = <&porte 2 0x00>;
        irq-gpio = <&portb 3 0x2002>;

        /* Caps */
        max_x = <1080>;
        max_y = <1240>;
        max_pressure = <0xff>;
        max_width_major = <1080>;
        max_width_minor = <1240>;
        max_orientation = <90>;
        max_id = <10>;
        hw_reset_delay = <40>;
        sw_reset_delay = <40>;

        /* role */
        use_lpwg = <1>;
        use_lpwg_test = <1>;
        hide_coordinate = <1>;
        use_activepen_status = <0>;
        use_film_status = <1>;
        use_dex_mode = <1>;

        /* Firmware */
        fw_image = "touch/winglm/V1W39WING_v0.18.img";
        panel_spec = "touch/winglm/wing_sw42000_limit.txt";
        panel_spec_mfts_folder = "touch/winglm/wing_sw42000_limit.txt";

        /* Performance Test */
        use_perf_test = <1>;
        test_delay = <8>;
        test_pressure = <50>;
        test_width = <100>;
        click_test_x = <180>;
        click_test_y = <838>;
        v_drag_test_x = <144>;
        v_drag_test_start_y = <2103>;
        v_drag_test_end_y = <1216>;
        h_drag_test_start_x = <1163>;
        h_drag_test_end_x = <276>;
        h_drag_test_y = <2284>;
    };

	gt9xx: gt9xx@14 {
		compatible = "goodix,gt9xx";
		reg = <0x14>;
		goodix,irq-gpio = <&porta 18 0>;
		goodix,rst-gpio = <&porta 19 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};
};

&spi3 {
	status = "okay";

	spidev@0 {
		status = "okay";
	};
};

&dac {
	/delete-property/ mute-gpio-l;
	/delete-property/ mute-gpio-r;
};

/* mipi dsi for u-boot */
&vo {
	compatible = "cvitek,vo";
	reset-gpio = <&porte 1 GPIO_ACTIVE_LOW>;
	pwm-gpio = <&porta 28 GPIO_ACTIVE_HIGH>;
	power-ct-gpio = <&porte 0 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

/* mipi dsi for kernel */
&mipi_tx {
	compatible = "cvitek,mipi_tx";
	reset-gpio = <&porte 1 GPIO_ACTIVE_LOW>;
	pwm-gpio = <&porta 28 GPIO_ACTIVE_HIGH>;
	power-ct-gpio = <&porte 0 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

&wifisd {
	status = "okay";
	cap-sd-highspeed;
	sd-uhs-sdr25;
	sd-uhs-ddr50;
	sd-uhs-sdr104;
	min-frequency = <400000>;
	max-frequency = <187500000>;
};

&wifi_pin {
	status = "okay";
	compatible = "cvitek,wifi-pin";
	poweron-gpio = <&porta 15 GPIO_ACTIVE_HIGH>;
	wakeup-gpio = <&porte 7 GPIO_ACTIVE_HIGH>;
};

&usb {
	vbus-gpio = <&portb 6 0>;
};

&uart1 {
	status = "okay";
};

&uart2 {
	status = "okay";
};

&uart3 {
	status = "okay";
};

&uart4 {
	status = "okay";
};
